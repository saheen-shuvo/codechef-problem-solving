#include <iostream>
#include <vector>
#include <algorithm>
#include <cmath>
#include <string>

using namespace std;

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int t;
    cin >> t;
    while (t--)
    {
        int n;
        cin >> n;
        vector<int> v(n);
        for(int i=0; i<n; i++){
            cin >> v[i];
        }
        sort(v.begin(), v.end());
        int ans = 0;
        int minimum = v[0];
        int maximum = v[n-1];
        for(int i=0; i<n; i++){
            if(v[i] > minimum && v[i] < maximum){
                ans++;
            }
        }
        cout << ans << '\n';
    }
    return 0;
}
